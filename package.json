{
  "name": "job-schedular-system",
  "version": "1.0.0",
  "description": "Task and job scheduling system with Node.js, TypeScript, Prisma and Kafka",
  "main": "src/index.ts",
  "type": "module",
  "author": "Koutilya Kumar Namdeo",
  "license": "ISC",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "consumer": "ts-node src/worker/kafkaConsumer.ts",
    "consumer:prod": "node dist/src/consumer.js",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "build": "prisma generate && tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koutilyanamdeo/Job-Schedular-System.git"
  },
  "bugs": {
    "url": "https://github.com/koutilyanamdeo/Job-Schedular-System/issues"
  },
  "homepage": "https://github.com/koutilyanamdeo/Job-Schedular-System#readme"
}
